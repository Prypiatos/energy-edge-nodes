#!/usr/bin/env sh

set -eu

commit_msg_file="$1"
first_line="$(sed -n '1p' "$commit_msg_file")"

pattern='^(feat|fix|docs|refactor|test|chore|build|ci|perf|revert)(\([a-z0-9._/-]+\))?: .+'

if printf '%s\n' "$first_line" | grep -Eq "$pattern"; then
    exit 0
fi

cat <<'EOF'
Invalid commit message.

Expected format:
  type(scope): summary
  type: summary

Allowed types:
  feat, fix, docs, refactor, test, chore, build, ci, perf, revert

Examples:
  feat(mqtt): add reconnect backoff
  fix(sensor): guard invalid PZEM readings
  docs: document node topics
EOF

exit 1
